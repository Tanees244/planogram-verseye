      "regex": "^/api/planogram/rows/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/planogram/rows/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
